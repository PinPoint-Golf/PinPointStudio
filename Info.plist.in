<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>PinPoint Studio</string>
    <key>CFBundleExecutable</key>
    <string>PinPointStudio</string>
    <key>CFBundleIdentifier</key>
    <string>com.pinpoint-golf.pinpointstudio</string>
    <key>CFBundleName</key>
    <string>PinPointStudio</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleIconFile</key>
    <string>PinPointStudio</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>PinPoint Studio uses the camera to capture and analyse your golf swing.</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>PinPoint Studio uses Bluetooth to connect to the IMU sensor on your club.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>PinPoint Studio uses speech recognition for hands-free control.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>PinPoint Studio needs microphone access for voice commands.</string>
</dict>
</plist>
