<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>PinPoint</string>
    <key>CFBundleIdentifier</key>
    <string>com.pinpoint-golf.PinPoint</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>PinPoint</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1</string>
    <key>CFBundleVersion</key>
    <string>0.1</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>PinPoint connects to the WT9011DCL Bluetooth IMU sensor to capture motion data during your golf swing.</string>
    <key>NSCameraUsageDescription</key>
    <string>PinPoint captures video from the camera to record and analyse your golf swing.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>PinPoint records audio through the microphone to transcribe speech in real time.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>PinPoint uses speech recognition to transcribe audio captured during your session.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSSupportsAutomaticGraphicsSwitching</key>
    <true/>
</dict>
</plist>
